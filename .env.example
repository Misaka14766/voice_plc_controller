# ASR 提供商
ASR_PROVIDER=funasr
ASR_SAMPLE_RATE=16000

# FunASR 模型
ASR_MODEL=paraformer-zh-streaming
ASR_DEVICE=cpu

# FunASR 流式参数
# [0,10,5] 对应每次处理10帧（600ms），步长5帧
ASR_CHUNK_SIZE=0,10,5
ASR_ENCODER_CHUNK_LOOK_BACK=4
ASR_DECODER_CHUNK_LOOK_BACK=1

# TTS
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_VOLUME=0.8

# LLM (DeepSeek 示例)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# PLC
PLC_ENABLED=false
PLC_PROVIDER=mock
PLC_AMS_NET_ID=192.168.1.1.1.1
PLC_AMS_PORT=851
PLC_IP_ADDRESS=192.168.1.100

# 按键
TRIGGER_KEY=ctrl_r

# 交互模式
VOICE_INPUT_ENABLED=true
VOICE_OUTPUT_ENABLED=true

# 模板匹配
USE_TEMPLATE_MATCHING=true

# 日志
LOG_LEVEL=INFO
VERBOSE=true

# 监控变量（可选）
# MONITOR_VARIABLES=MAIN.Temperature:REAL,MAIN.Pressure:REAL,MAIN.Motor1:BOOL
# MONITOR_INTERVAL_MS=200
